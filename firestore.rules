rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /waitlist/{entry} {
      // Public landing form can add emails only.
      allow create: if request.resource.data.keys().hasOnly(['email', 'createdAt', 'source'])
        && request.resource.data.email is string
        && request.resource.data.email.size() > 3
        && request.resource.data.email.size() < 320
        && request.resource.data.source == 'landing';
      allow read, update, delete: if false;
    }
  }
}
